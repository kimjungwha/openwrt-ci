@@ -48,6 +48,13 @@
 			gpios = <&tlmm 70 GPIO_ACTIVE_HIGH>;
 		};
 	};
+
+	fan_pwm: pwm-fan {
+		compatible = "pwm-fan";
+		pwms = <&gpio_pwm 0 500000>;
+		cooling-levels = <0 64 128 192 255>;
+		#cooling-cells = <2>;
+	};
 };
 
 &wifi {
@@ -55,3 +62,24 @@
 	qcom,ath11k-fw-memory-mode = <1>;
 	qcom,ath11k-calibration-variant = "ZN-M2";
 };
+
+&soc {
+	gpio_pwm: pwm@0 {
+		compatible = "gpio-pwm";
+		#pwm-cells = <2>;
