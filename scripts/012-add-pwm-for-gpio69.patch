+};
+
+
+
+&soc {
+    // 添加 GPIO PWM 控制器（软件 PWM）
+    gpio_pwm: pwm@0 {
+        compatible = "gpio-pwm";
+        #pwm-cells = <2>;  // 参数: index, period (ns)
+        
+        pinctrl-names = "default";
+        pinctrl-0 = <&gpio69_pins>;
+        
+        gpios = <&tlmm 69 GPIO_ACTIVE_HIGH>;
+    };
+};
+
+&tlmm {  // pinctrl@1000000 的 label
+    // 添加 GPIO69 的引脚配置
+    gpio69_pins: gpio69-pins {
+        pins = "gpio69";
+        function = "gpio";
+        drive-strength = <8>;
+        bias-disable;
+        output-high;  // 默认输出高
+    };
+};
